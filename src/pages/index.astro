---
import Layout from '../layouts/Layout.astro';

// --- Kontaktdaten (hier zentral anpassbar) ---
const email = 'alexander.engel@wyld-it.de';
const github = 'https://github.com/Alengelander';
// TODO: Eigene LinkedIn-URL eintragen (oder Zeile in der Kontakt-Liste entfernen).
const linkedin = 'https://www.linkedin.com/in/';
---

<Layout
  title="Alexander Engel – Über mich"
  description="Alexander Engel – IT aus Leidenschaft. Erfahre mehr über mich und finde alle Kontaktmöglichkeiten."
>
  <section class="hero">
    <div class="container">
      <p class="eyebrow">Hallo, ich bin</p>
      <h1>Alexander Engel</h1>
      <!-- TODO: Rolle/Untertitel anpassen -->
      <p class="tagline">IT-Consultant &amp; Softwareentwickler</p>
      <!-- TODO: Einleitungssatz personalisieren -->
      <p class="lede">
        Ich helfe dabei, IT einfacher, sicherer und zukunftsfähig zu machen –
        von der ersten Idee bis zum laufenden Betrieb.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <h2>Über mich</h2>
      <!-- TODO: Text durch deine eigene Geschichte ersetzen -->
      <p>
        Schön, dass du hier bist. Ich bin Alexander Engel und in der IT zu Hause –
        von der Softwareentwicklung über Cloud-Infrastruktur bis hin zur Beratung.
        Aktuell bin ich Teil des Teams bei wyld-it.
      </p>
      <p>
        Mich begeistert es, komplexe Anforderungen in saubere, wartbare Lösungen
        zu übersetzen und Technik so einzusetzen, dass sie den Menschen wirklich
        weiterhilft.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <h2>Schwerpunkte</h2>
      <!-- TODO: Schwerpunkte anpassen oder ergänzen -->
      <ul class="focus-list">
        <li>
          <h3>Softwareentwicklung</h3>
          <p>
            Moderne Web- und Backend-Anwendungen – von der Idee bis zum
            produktiven Betrieb.
          </p>
        </li>
        <li>
          <h3>Cloud &amp; Infrastruktur</h3>
          <p>
            Skalierbare, sichere Infrastruktur und Automatisierung, die im Alltag
            verlässlich trägt.
          </p>
        </li>
        <li>
          <h3>Beratung &amp; Projekte</h3>
          <p>
            Pragmatische Beratung, die Technik und Business zusammenbringt.
          </p>
        </li>
      </ul>
    </div>
  </section>

  <section class="section" id="kontakt">
    <div class="container">
      <h2>Kontakt</h2>
      <p>
        Du möchtest dich vernetzen oder hast eine Frage? Ich freue mich, von dir
        zu hören.
      </p>
      <dl class="contact">
        <div class="contact-row">
          <dt>E-Mail</dt>
          <dd><a href={`mailto:${email}`}>{email}</a></dd>
        </div>
        <div class="contact-row">
          <dt>GitHub</dt>
          <dd><a href={github} rel="me">@Alengelander</a></dd>
        </div>
        <div class="contact-row">
          <dt>LinkedIn</dt>
          <dd><a href={linkedin} rel="me">Alexander Engel</a></dd>
        </div>
      </dl>
    </div>
  </section>
</Layout>
