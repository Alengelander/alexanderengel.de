---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  showHeader?: boolean;
}

const {
  title = 'Alexander Engel',
  description = 'Persönliche Website von Alexander Engel – Profil und Kontaktmöglichkeiten.',
  showHeader = true,
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site);
const year = new Date().getFullYear();
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical.href} />
    <meta name="generator" content={Astro.generator} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical.href} />
    <meta property="og:site_name" content="Alexander Engel" />
    <meta property="og:locale" content="de_DE" />
    <meta name="twitter:card" content="summary" />

    <meta
      name="theme-color"
      content="#e4e8ef"
      media="(prefers-color-scheme: light)"
    />
    <meta
      name="theme-color"
      content="#2b2f36"
      media="(prefers-color-scheme: dark)"
    />
  </head>
  <body>
    {
      showHeader && (
        <header class="site-header">
          <div class="container">
            <a href="/" class="wordmark">
              Alexander&nbsp;Engel
            </a>
          </div>
        </header>
      )
    }

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <div class="container footer-inner">
        <nav class="footer-nav" aria-label="Rechtliches">
          <a href="/impressum/">Impressum</a>
          <a href="/datenschutz/">Datenschutz</a>
        </nav>
        <p class="copyright">© {year} Alexander Engel</p>
      </div>
    </footer>

    <script is:inline>
      // Dynamischer Neumorphismus-Lichteffekt auf Mobilgeraeten: Die Lichtrichtung
      // (--nm-sx / --nm-sy) folgt der Geraeteneigung (Gyroskop). Ohne Sensor, ohne
      // JS oder bei "prefers-reduced-motion" bleiben die statischen Schatten.
      (function () {
        var root = document.documentElement;
        if (typeof DeviceOrientationEvent === 'undefined') return;
        if (
          window.matchMedia &&
          window.matchMedia('(prefers-reduced-motion: reduce)').matches
        )
          return;

        var curX = 1,
          curY = 1,
          tgtX = 1,
          tgtY = 1,
          raf = 0,
          active = false;
        function clamp(v, lo, hi) {
          return v < lo ? lo : v > hi ? hi : v;
        }

        function tick() {
          curX += (tgtX - curX) * 0.12;
          curY += (tgtY - curY) * 0.12;
          root.style.setProperty('--nm-sx', curX.toFixed(3));
          root.style.setProperty('--nm-sy', curY.toFixed(3));
          if (Math.abs(tgtX - curX) > 0.001 || Math.abs(tgtY - curY) > 0.001) {
            raf = requestAnimationFrame(tick);
          } else {
            raf = 0;
          }
        }

        function onOrient(e) {
          if (e.gamma == null && e.beta == null) return;
          var gx = clamp((e.gamma || 0) / 35, -1, 1);
          var gy = clamp(((e.beta || 0) - 45) / 35, -1, 1);
          tgtX = clamp(1 - gx * 1.2, -0.4, 2);
          tgtY = clamp(1 - gy * 1.2, -0.4, 2);
          if (!raf) raf = requestAnimationFrame(tick);
        }

        function start() {
          if (active) return;
          active = true;
          window.addEventListener('deviceorientation', onOrient, true);
        }

        if (typeof DeviceOrientationEvent.requestPermission === 'function') {
          // iOS 13+: Sensorzugriff erst nach einer Nutzergeste erlaubt
          window.addEventListener(
            'click',
            function ask() {
              DeviceOrientationEvent.requestPermission()
                .then(function (s) {
                  if (s === 'granted') start();
                })
                .catch(function () {});
            },
            { once: true }
          );
        } else {
          start();
        }
      })();
    </script>
  </body>
</html>
